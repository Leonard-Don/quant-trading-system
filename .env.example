# 量化交易系统环境配置示例
# 复制此文件为 .env 并根据需要修改配置

# =============================================================================
# 基础配置
# =============================================================================

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# 项目环境
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# 数据配置
# =============================================================================

# 数据缓存配置
DATA_CACHE_SIZE=100
CACHE_TTL=3600
DEFAULT_LOOKBACK_DAYS=365

# 数据源配置
YFINANCE_TIMEOUT=30
DATA_REFRESH_INTERVAL=300

# =============================================================================
# 交易配置
# =============================================================================

# 默认交易参数
DEFAULT_INITIAL_CAPITAL=10000.0
DEFAULT_COMMISSION=0.001
DEFAULT_SLIPPAGE=0.001

# 风险管理
MAX_POSITION_SIZE=0.1
STOP_LOSS_THRESHOLD=0.05
TAKE_PROFIT_THRESHOLD=0.15

# =============================================================================
# API配置
# =============================================================================

# 服务器配置
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true
API_TIMEOUT=30

# 前端配置
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# =============================================================================
# 性能配置
# =============================================================================

# 并发配置
MAX_WORKERS=4
ASYNC_POOL_SIZE=10

# 缓存配置
CACHE_MAX_MEMORY_ITEMS=1000
CACHE_CLEANUP_INTERVAL=3600

# =============================================================================
# 监控配置
# =============================================================================

# 健康检查
HEALTH_CHECK_TIMEOUT=10
BACKEND_WAIT_TIMEOUT=30

# 系统监控阈值
CPU_WARNING_THRESHOLD=80.0
MEMORY_WARNING_THRESHOLD=85.0
DISK_WARNING_THRESHOLD=90.0

# 性能监控
PERFORMANCE_LOG_THRESHOLD=1.0
SLOW_QUERY_THRESHOLD=5.0

# =============================================================================
# 安全配置
# =============================================================================

# API安全
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_REQUEST_SIZE=10485760

# 数据安全
ENABLE_DATA_ENCRYPTION=false
ENCRYPTION_KEY=""

# 审计日志
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90

# =============================================================================
# 开发配置
# =============================================================================

# 测试配置
TEST_DATA_PATH=tests/data
MOCK_EXTERNAL_APIS=false

# 调试配置
ENABLE_PROFILING=false
PROFILE_OUTPUT_DIR=profiles

# 开发工具
AUTO_RELOAD=true
ENABLE_DEBUG_TOOLBAR=false

# =============================================================================
# 生产配置
# =============================================================================

# 生产环境特定配置（当ENVIRONMENT=production时生效）
PROD_LOG_LEVEL=WARNING
PROD_API_HOST=0.0.0.0
PROD_DEBUG=false
PROD_AUTO_RELOAD=false

# 数据库配置（如果使用数据库）
DATABASE_URL=""
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30

# 外部服务配置
REDIS_URL=""
ELASTICSEARCH_URL=""

# =============================================================================
# 通知配置
# =============================================================================

# 邮件通知
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_USE_TLS=true

# 钉钉/企业微信通知
DINGTALK_WEBHOOK=""
WECHAT_WEBHOOK=""

# =============================================================================
# 备份配置
# =============================================================================

# 自动备份
ENABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=backups
